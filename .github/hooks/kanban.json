{
  "version": 1,
  "hooks": {
    "agentStop": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'to_review' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"to_review\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "subagentStop": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'activity' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"activity\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'activity' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"activity\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "permissionRequest": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'activity' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"activity\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'activity' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"activity\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "postToolUseFailure": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'activity' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"activity\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "userPromptSubmitted": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'to_in_progress' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"to_in_progress\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ],
    "notification": [
      {
        "type": "command",
        "bash": "'cy' 'hooks' 'notify' '--event' 'activity' '--source' 'copilot'",
        "powershell": "\"cy\" \"hooks\" \"notify\" \"--event\" \"activity\" \"--source\" \"copilot\"",
        "timeoutSec": 5
      }
    ]
  }
}
