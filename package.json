{
  "name": "changeyard",
  "version": "0.1.0",
  "description": "Generic markdown-first local change workflow manager prototype.",
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "bin": {
    "changeyard": "./scripts/cy.mjs",
    "cy": "./scripts/cy.mjs"
  },
	"scripts": {
		"build:cli": "tsc -p tsconfig.json && mkdir -p dist/src/templates dist/src/planning/templates/prompts dist/src/docs && cp src/templates/*.md dist/src/templates/ && cp src/planning/templates/prompts/*.md dist/src/planning/templates/prompts/ && cp -R docs/cli dist/src/docs/",
		"build:merge": "pnpm --filter @changeyard/merge run build",
		"build:vcs": "pnpm --filter @changeyard/vcs run build",
		"build:kanban": "pnpm --filter @changeyard/kanban run build",
		"build:tui": "pnpm --filter @changeyard/tui run build",
		"build:desktop": "pnpm --filter @changeyard/desktop run build",
		"build:docs": "pnpm --filter @changeyard/docs run build",
		"dev:desktop": "pnpm --filter @changeyard/desktop install && pnpm run build:cli && pnpm run build:kanban && pnpm --filter @changeyard/desktop run dev",
		"dev:desktop:vite": "pnpm --filter @changeyard/desktop install && pnpm run build:cli && pnpm run build:kanban && pnpm --filter @changeyard/desktop run dev:vite",
		"build": "pnpm run build:cli && pnpm run build:merge && pnpm run build:vcs && pnpm run build:kanban && pnpm run build:tui",
		"docs:dev": "pnpm --filter @changeyard/docs run dev",
    "docs:build": "pnpm run build:docs",
    "docs:check": "pnpm --filter @changeyard/docs run check",
		"docs:preview": "pnpm --filter @changeyard/docs run preview",
		"cli": "node scripts/cy.mjs",
    "cy": "node scripts/cy.mjs",
    "cy:dev": "CHANGEYARD_DEV=1 node scripts/cy.mjs",
    "ui:dev": "tsx watch --clear-screen=false scripts/ui-dev.ts",
    "ui:vcs:dev": "tsx watch --clear-screen=false scripts/ui-vcs-dev.ts",
    "vcs:fixture": "node --import tsx scripts/create-vcs-jj-fixture.ts",
    "vcs:git-fixture": "node --import tsx scripts/create-vcs-git-fixture.ts",
    "vcs:jj-scenarios": "node --import tsx scripts/create-vcs-jj-scenarios.ts",
    "vcs:jj-scenario": "node --import tsx scripts/create-vcs-jj-scenarios.ts --scenario",
    "kanban:scenarios": "node --import tsx scripts/create-kanban-scenarios.ts",
    "vcs:e2e": "pnpm --filter @changeyard/vcs run e2e",
    "cy:install": "pnpm run cy:dev -- install",
    "cy:uninstall": "pnpm run cy:dev -- uninstall",
    "test": "pnpm run build && node --test --test-force-exit dist/tests/*.test.js",
    "test:workspaces": "pnpm -r --if-present run test",
    "typecheck:workspaces": "pnpm -r --if-present run typecheck",
    "audit:dependencies": "node scripts/audit-dependencies.mjs",
    "check:package-manager": "node scripts/check-package-manager.mjs",
    "check:node": "pnpm run build:cli && pnpm --filter @changeyard/kanban run typecheck",
    "check:tui": "pnpm --filter @changeyard/tui run typecheck && node scripts/verify-tui-endpoints.mjs && pnpm --filter @changeyard/tui run test",
    "check": "pnpm run check:package-manager && pnpm run check:node",
    "check:all": "pnpm run check && pnpm run typecheck:workspaces && pnpm test && pnpm run test:workspaces && pnpm run docs:check && pnpm run audit:dependencies",
    "pack:check": "pnpm run build && pnpm pack --dry-run",
    "prepack": "pnpm run build",
    "smoke:tui": "node scripts/tui-smoke.mjs",
    "smoke:forge": "node scripts/live-forge-smoke.mjs",
    "smoke:install": "node scripts/smoke-install-from-tarball.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "tsx": "^4.23.1"
  },
  "files": [
    "dist/src",
    "packages/kanban/dist",
    "packages/kanban/package.json",
    "packages/kanban/README.md",
    "packages/merge/dist",
    "packages/merge/package.json",
    "packages/tui/dist",
    "packages/tui/package.json",
    "README.md",
    "docs",
    "scripts"
  ],
  "dependencies": {
    "@clinebot/core": "^0.0.38",
    "@clinebot/shared": "^0.0.38",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui/core": "0.1.102",
    "@opentui/react": "0.1.102",
    "@trpc/server": "^11.17.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "chokidar": "^5.0.0",
    "node-pty": "^1.2.0-beta.13",
    "open": "^11.0.0",
    "proper-lockfile": "^4.1.2",
    "react": "19.2.4",
    "react-devtools-core": "^7.0.1",
    "tree-kill": "^1.2.2",
    "undici": "^8.7.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "pnpm": {
    "overrides": {
      "diff@>=6.0.0 <8.0.3": "8.0.4",
      "jimp@1.6.0": "1.6.1",
      "esbuild@>=0.27.3 <0.28.1": "0.28.1",
      "@opentelemetry/core@<2.8.0": "2.9.0"
    }
  }
}
