{
  "name": "changeyard",
  "version": "0.1.0",
  "description": "Generic markdown-first local change workflow manager prototype.",
  "type": "module",
  "workspaces": [
    "packages/kanban",
    "packages/tui",
    "packages/vcs"
  ],
  "bin": {
    "changeyard": "./scripts/cy.mjs",
    "cy": "./scripts/cy.mjs"
  },
  "scripts": {
    "build:cli": "tsc -p tsconfig.json && mkdir -p dist/src/templates dist/src/planning/templates/prompts && cp src/templates/*.md dist/src/templates/ && cp src/planning/templates/prompts/*.md dist/src/planning/templates/prompts/",
    "build:vcs": "npm --workspace @changeyard/vcs run build",
    "build:kanban": "npm --workspace @changeyard/kanban run build",
    "build:tui": "npm --workspace @changeyard/tui run build",
    "build": "npm run build:cli && npm run build:vcs && npm run build:kanban",
    "cli": "node scripts/cy.mjs",
    "cy": "node scripts/cy.mjs",
    "cy:dev": "CHANGEYARD_DEV=1 node scripts/cy.mjs",
    "ui:dev": "node --import tsx scripts/ui-dev.ts",
    "ui:vcs:dev": "node --import tsx scripts/ui-vcs-dev.ts",
    "vcs:fixture": "node --import tsx scripts/create-vcs-jj-fixture.ts",
    "vcs:git-fixture": "node --import tsx scripts/create-vcs-git-fixture.ts",
    "vcs:e2e": "npm --workspace @changeyard/vcs run e2e",
    "cy:install": "npm run cy:dev -- install",
    "cy:uninstall": "npm run cy:dev -- uninstall",
    "test": "npm run build && node --test --test-force-exit dist/tests/*.test.js",
    "check:node": "npm run build:cli && npm --workspace @changeyard/kanban run typecheck",
    "check:tui": "npm --workspace @changeyard/tui run typecheck && node scripts/verify-tui-endpoints.mjs && npm --workspace @changeyard/tui run test",
    "check": "npm run check:node",
    "pack:check": "npm run build && npm pack --dry-run",
    "prepack": "npm run build",
    "smoke:tui": "node scripts/tui-smoke.mjs",
    "smoke:forge": "node scripts/live-forge-smoke.mjs",
    "smoke:install": "node scripts/smoke-install-from-tarball.mjs"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "tsx": "^4.21.0"
  },
  "files": [
    "dist/src",
    "packages/kanban/dist",
    "packages/kanban/package.json",
    "packages/kanban/README.md",
    "packages/tui/src",
    "packages/tui/package.json",
    "packages/tui/tsconfig.json",
    "README.md",
    "docs",
    "scripts"
  ]
}
