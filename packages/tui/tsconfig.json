{
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "customConditions": ["browser"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"]
  },
  "include": [
    "src/index.tsx",
    "src/runtime-client.ts",
    "src/react/**/*.ts",
    "src/react/**/*.tsx",
    "src/utils/activity.ts",
    "src/utils/activity-events.ts",
    "src/utils/command-search.ts",
    "src/utils/diagnostic-bundle.ts",
    "src/utils/diagnostics.ts",
    "src/utils/prompt-history.ts",
    "src/utils/status-format.ts",
    "tests/**/*.ts",
    "tests/**/*.tsx"
  ]
}
