{
  "name": "@changeyard/tui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "build": "bun build src/index.tsx --outdir dist --target bun --external @opentui/core-darwin-x64 --external @opentui/core-darwin-arm64 --external @opentui/core-linux-x64 --external @opentui/core-linux-arm64 --external @opentui/core-linux-x64-musl --external @opentui/core-linux-arm64-musl --external @opentui/core-win32-x64 --external @opentui/core-win32-arm64",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@opentui/core": "^0.4.0",
    "@opentui/react": "^0.4.0",
    "react": "^19.2.3"
  },
  "devDependencies": {
    "@types/node": "^24.10.2",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3"
  }
}
