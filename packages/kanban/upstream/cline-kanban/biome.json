{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"useConst": "error"
			},
			"suspicious": {
				"noExplicitAny": "off"
			}
		}
	},
	"files": {
		"includes": [
			"src/**/*.ts",
			"src/**/*.tsx",
			"test/**/*.ts",
			"vitest.config.ts",
			"web-ui/src/**/*.ts",
			"web-ui/src/**/*.tsx",
			"web-ui/tests/**/*.ts",
			"web-ui/vite.config.ts",
			"web-ui/vitest.config.ts",
			"web-ui/playwright.config.ts",
			"!dist/**/*",
			"!node_modules/**/*",
			"!!**/node_modules",
			"!.worktrees/**/*"
		]
	},
	"plugins": ["grit/no-process-env-destructure.grit", "grit/no-home-agent-prefix-literal.grit"],
	"overrides": [
		{
			"includes": ["src/**/*.ts", "src/**/*.tsx", "!src/cli.ts"],
			"plugins": ["grit/no-console.grit", "grit/no-process-exit.grit"]
		},
		{
			"includes": ["src/**/*.ts", "src/**/*.tsx", "!src/cline-sdk/**/*.ts"],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"patterns": [
									{
										"group": ["@clinebot/core", "@clinebot/core/**"],
										"message": "Import Cline SDK packages only through src/cline-sdk/sdk-provider-boundary.ts or src/cline-sdk/sdk-runtime-boundary.ts."
									}
								]
							}
						}
					}
				}
			}
		},
		{
			"includes": ["web-ui/src/**/*.ts", "web-ui/src/**/*.tsx", "web-ui/tests/**/*.ts"],
			"linter": {
				"rules": {
					"a11y": {
						"noNoninteractiveTabindex": "off",
						"noStaticElementInteractions": "off",
						"noSvgWithoutTitle": "off",
						"useAriaPropsForRole": "off",
						"useFocusableInteractive": "off",
						"useKeyWithClickEvents": "off",
						"useSemanticElements": "off"
					},
					"complexity": {
						"noUselessFragments": "off"
					},
					"correctness": {
						"useExhaustiveDependencies": "off"
					},
					"security": {
						"noDangerouslySetInnerHtml": "off"
					},
					"style": {
						"noNonNullAssertion": "off"
					},
					"suspicious": {
						"noArrayIndexKey": "off"
					}
				}
			}
		},
		{
			"includes": [
				"web-ui/src/**/*.ts",
				"web-ui/src/**/*.tsx",
				"!web-ui/src/runtime/runtime-config-query.ts",
				"!web-ui/src/runtime/workspace-state-query.ts"
			],
			"linter": {
				"rules": {
					"style": {
						"noRestrictedImports": {
							"level": "error",
							"options": {
								"paths": {
									"@/runtime/trpc-client": {
										"importNames": ["createWorkspaceTrpcClient"],
										"message": "Use getRuntimeTrpcClient in components and hooks. Reserve createWorkspaceTrpcClient for the runtime query helpers."
									}
								}
							}
						}
					}
				}
			}
		}
	]
}
