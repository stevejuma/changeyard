#!/bin/sh

STAGED_FILES=$(git diff --cached --name-only)

echo "Running biome check on staged files..."
npx biome check --staged --no-errors-on-unmatched --files-ignore-unknown=true
if [ $? -ne 0 ]; then
	echo "Biome check failed."
	exit 1
fi

echo "Running type checking and fast tests..."
npm run typecheck && npm run test:precommit
if [ $? -ne 0 ]; then
	echo "Checks failed."
	exit 1
fi

for file in $STAGED_FILES; do
	if [ -f "$file" ]; then
		git add "$file"
	fi
done

echo "Pre-commit checks passed."
