{
  "name": "@changeyard/kanban",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./server": "./dist/server/index.js"
  },
  "scripts": {
    "web:build": "pnpm --dir web-ui run build",
    "web:typecheck": "pnpm --dir web-ui run typecheck",
    "build": "pnpm run web:build && pnpm run runtime:build && node scripts/build.mjs",
    "typecheck": "node --check src/index.js && node --check src/server/index.js && pnpm run web:typecheck && pnpm exec tsc -p tsconfig.runtime.json --noEmit",
    "test": "node --test",
    "runtime:build": "pnpm exec tsc -p tsconfig.runtime.json",
    "runtime:typecheck": "pnpm exec tsc -p tsconfig.runtime.json --noEmit"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@clinebot/core": "^0.0.38",
    "@clinebot/shared": "^0.0.38",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@trpc/server": "^11.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/headless": "^6.0.0",
    "chokidar": "^5.0.0",
    "node-pty": "^1.2.0-beta.11",
    "open": "^11.0.0",
    "proper-lockfile": "^4.1.2",
    "tree-kill": "^1.2.2",
    "undici": "^8.4.1",
    "ws": "^8.18.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/proper-lockfile": "^4.1.4",
    "@types/ws": "^8.18.1"
  }
}
